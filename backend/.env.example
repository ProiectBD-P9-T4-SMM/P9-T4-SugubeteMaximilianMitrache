# Backend Environment Variables

# ─── Server ───────────────────────────────────────────────────────────────
# Port the backend listens on
PORT=3000

# CORS allowed origins (comma-separated)
# Local: http://localhost:5173
# GitHub Pages: https://proiectbd-p9-t4-smm.github.io
# Oracle VM: http://79.76.96.223:3000 (or HTTPS domain after SSL setup)
ALLOWED_ORIGINS=http://localhost:5173,https://proiectbd-p9-t4-smm.github.io

# ─── Database ─────────────────────────────────────────────────────────────
# Oracle Database connection details
DB_HOST=localhost
DB_PORT=1521
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

# ─── Authentication ───────────────────────────────────────────────────────
# JWT secret key (use strong, random value in production)
JWT_SECRET=your_jwt_secret_key_change_in_production

# ─── Email ────────────────────────────────────────────────────────────────
# Email provider: mock, smtp, or graph
EMAIL_PROVIDER=mock

# Microsoft Graph Email Configuration (if using GRAPH provider)
GRAPH_TENANT_ID=your_tenant_id
GRAPH_CLIENT_ID=your_client_id
GRAPH_CLIENT_SECRET=your_client_secret
GRAPH_SENDER_EMAIL=noreply@yourdomain.com

# SMTP Email Configuration (if using SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
